# Copia este archivo a .env y completa con tus credenciales
# NUNCA commitees el .env real a git

# ----------------------------------------------------------------------
# Protocolo. Default sftp (mas seguro).
#   sftp = FTP sobre SSH (puerto 22)         <- recomendado, encriptado
#   ftps = FTP sobre TLS (puerto 21 o 990)   <- encriptado
#   ftp  = FTP plano (puerto 21)             <- creds en cleartext, evitar
# ----------------------------------------------------------------------
FTP_PROTOCOL=sftp

FTP_HOST=tu-host.example.com
FTP_USER=tu-usuario
FTP_PASS=tu-password
FTP_PATH=/public_html

# Default segun protocolo: sftp=22, ftp/ftps=21. Solo setear si tu hosting usa otro.
# FTP_PORT=22

# ----------------------------------------------------------------------
# Solo SFTP: opcional, autenticacion por private key en lugar de password
# Si seteas SFTP_KEY_PATH, FTP_PASS se ignora.
# ----------------------------------------------------------------------
# SFTP_KEY_PATH=/home/usuario/.ssh/id_rsa
# SFTP_KEY_PASSPHRASE=

# ----------------------------------------------------------------------
# Whitelist de archivos/carpetas esperados en el root del sitio.
# Cualquier cosa fuera de esta lista se reporta como sospechosa.
# Personalizalo segun tu sitio. Default razonable abajo:
# ----------------------------------------------------------------------
EXPECTED_ROOT=index.html,index.php,robots.txt,sitemap.xml,favicon.ico,.htaccess,css,js,img,images,assets,fonts

# ----------------------------------------------------------------------
# Legacy: se mantiene por compatibilidad. Si seteas FTP_PROTOCOL ignoralo.
# FTP_SECURE=true  --> equivale a FTP_PROTOCOL=ftps
# ----------------------------------------------------------------------
# FTP_SECURE=false
