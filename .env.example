# Copy this file to .env and fill in your credentials.
# NEVER commit the real .env to git.

# ----------------------------------------------------------------------
# Protocol. Default is sftp (the secure choice).
#   sftp = FTP over SSH (port 22)            <- recommended, encrypted
#   ftps = FTP over TLS (port 21 or 990)     <- encrypted
#   ftp  = plain FTP (port 21)               <- creds in cleartext, avoid
# ----------------------------------------------------------------------
FTP_PROTOCOL=sftp

FTP_HOST=your-host.example.com
FTP_USER=your-username
FTP_PASS=your-password
FTP_PATH=/public_html

# Default by protocol: sftp=22, ftp/ftps=21. Only set if your host uses another port.
# FTP_PORT=22

# ----------------------------------------------------------------------
# SFTP only: optional, authenticate with a private key instead of password
# If SFTP_KEY_PATH is set, FTP_PASS is ignored.
# ----------------------------------------------------------------------
# SFTP_KEY_PATH=/home/user/.ssh/id_rsa
# SFTP_KEY_PASSPHRASE=

# ----------------------------------------------------------------------
# Whitelist of files and folders expected in the site root.
# Anything outside this list is reported as suspicious.
# Customize per your site. Reasonable default below:
# ----------------------------------------------------------------------
EXPECTED_ROOT=index.html,index.php,robots.txt,sitemap.xml,favicon.ico,.htaccess,css,js,img,images,assets,fonts

# ----------------------------------------------------------------------
# Legacy: kept for backwards compatibility. If you set FTP_PROTOCOL ignore this.
# FTP_SECURE=true  --> equivalent to FTP_PROTOCOL=ftps
# ----------------------------------------------------------------------
# FTP_SECURE=false
